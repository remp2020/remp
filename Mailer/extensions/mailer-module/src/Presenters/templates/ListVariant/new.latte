{layout '../@layout.latte'}

{block #content}

<div class="c-header">
    <h2>Newsletter list variant</h2>
</div>
<div class="card">
    <div class="card-header">
        <h2 n:block="title">Add new variant <small>{$mailType->title}</small></h2>
        <div class="actions">
            <a n:href="List:show $mailType->id">
                <button type="button" class="btn palette-Cyan bg waves-effect"><i class="zmdi zmdi-long-arrow-return"></i> Back to list</button>
            </a>
        </div>
    </div>
    <div class="card-body card-padding">
        {include '@form.latte'}
    </div>
</div>
