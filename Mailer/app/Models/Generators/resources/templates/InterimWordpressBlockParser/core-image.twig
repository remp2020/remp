<!-- core/image -->
{% if imageAlign == 'center' %}
<div style="text-align: center;">
    {% if href %}<a href="{{ href }}" target="_blank" style="display: inline-block; border: none; margin: 0; padding: 0; text-decoration: none;">{% endif %}
    <img src="{{ url }}" width="{{ imageWidth|replace({'px': ''}) }}" style="max-width: {{ imageWidth }}; height: auto; display: inline-block; border-radius: 10px;"
         {% if alt %}alt="{{ alt }}"{% endif %}
    >
    {% if href %}</a>{% endif %}
</div>
{% else %}
    {% if href %}<a href="{{ href }}" target="_blank" style="display: block; border: none; margin: 0; padding: 0; text-decoration: none;">{% endif %}
        <img src="{{ url }}" width="{{ imageWidth|replace({'px': ''}) }}" style="width: 100%; max-width: {{ imageWidth }}; height: auto; display: block; border-radius: 10px;"
             {% if alt %}alt="{{ alt }}"{% endif %}
        >
    {% if href %}</a>{% endif %}
{% endif %}
<!-- end core/image -->
